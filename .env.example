# ── Email / SMTP configuration ─────────────────────────────────
# Copy this file to .env and fill in your real credentials.
# Never commit .env — it is already listed in .gitignore.

# SMTP server hostname (default: smtp.gmail.com)
SMTP_HOST=smtp.gmail.com

# SMTP port — 587 for STARTTLS (recommended), 465 for SSL
SMTP_PORT=587

# Login credentials for the sending account
# For Gmail: use an App Password (not your main password).
# Generate one at: Google Account → Security → 2-Step Verification → App passwords
SMTP_USER=your-address@gmail.com
SMTP_PASS=your-app-password-here

# "From" address shown in the recipient's inbox.
# Leave blank to use SMTP_USER.
EMAIL_FROM=

# ── Receipt inbox/reviewed folders ──────────────────────────────
# Set these to your Dropbox (or other cloud) folder paths.
# Leave blank to use local data/receipts/inbox and data/receipts/reviewed.
# Windows example: C:\Users\YourName\Dropbox\Small Jobs\Inbox
# Mac example:     /Users/yourname/Dropbox/Small Jobs/Inbox
RECEIPT_INBOX=
RECEIPT_REVIEWED=


